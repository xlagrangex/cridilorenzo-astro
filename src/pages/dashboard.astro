---
export const prerender = false;
---
<!doctype html>
<html lang="it">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Dashboard — Christian Di Lorenzo</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: "DM Sans", system-ui, sans-serif; background: #f4f2ee; color: #15141a; min-height: 100vh; }

    .login-wrap { display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 20px; }
    .login-card { background: white; border-radius: 20px; padding: 40px; max-width: 380px; width: 100%; box-shadow: 0 4px 24px rgba(0,0,0,0.06); }
    .login-card h1 { font-size: 1.5rem; font-weight: 500; margin-bottom: 8px; }
    .login-card p { color: #3e3e3e; font-size: 0.9rem; margin-bottom: 24px; }
    .login-card input { width: 100%; padding: 12px 16px; border: 1px solid #e4e4e4; border-radius: 10px; font-size: 1rem; margin-bottom: 16px; background: #f4f2ee; }
    .login-card input:focus { outline: none; border-color: #2a9d8f; }
    .login-card button { width: 100%; padding: 14px; background: #2a9d8f; color: white; border: none; border-radius: 12px; font-size: 1rem; font-weight: 600; cursor: pointer; }
    .login-card button:hover { background: #238b7f; }
    .login-error { color: #e53e3e; font-size: 0.85rem; margin-bottom: 12px; display: none; }

    .dashboard { display: none; max-width: 1200px; margin: 0 auto; padding: 24px; }
    .dash-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 32px; flex-wrap: wrap; gap: 16px; }
    .dash-header h1 { font-size: 1.75rem; font-weight: 500; }
    .dash-tabs { display: flex; gap: 8px; }
    .dash-tab { padding: 8px 20px; border-radius: 10px; border: 1px solid #e4e4e4; background: white; font-size: 0.9rem; cursor: pointer; font-weight: 500; transition: all 0.2s; }
    .dash-tab:hover { border-color: #2a9d8f; }
    .dash-tab.active { background: #2a9d8f; color: white; border-color: #2a9d8f; }

    .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 32px; }
    .stat-card { background: white; border-radius: 15px; padding: 20px; }
    .stat-card .label { font-size: 0.8rem; color: #929292; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px; }
    .stat-card .value { font-size: 2rem; font-weight: 600; color: #2a9d8f; }

    .table-wrap { background: white; border-radius: 15px; overflow: hidden; }
    table { width: 100%; border-collapse: collapse; }
    th { text-align: left; padding: 14px 20px; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: #929292; border-bottom: 1px solid #e4e4e4; font-weight: 500; }
    td { padding: 14px 20px; border-bottom: 1px solid #f4f2ee; font-size: 0.9rem; vertical-align: top; }
    tr:last-child td { border-bottom: none; }
    tr:hover { background: #faf9f7; }
    .badge { display: inline-block; padding: 3px 10px; border-radius: 6px; font-size: 0.75rem; font-weight: 600; }
    .badge-contatto { background: #2a9d8f20; color: #2a9d8f; }
    .badge-newsletter { background: #9eaafa30; color: #6366f1; }
    .badge-unread { background: #fef3c7; color: #d97706; }
    .msg-preview { max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: #3e3e3e; }
    .empty { padding: 60px 20px; text-align: center; color: #929292; }

    .logout-btn { padding: 8px 16px; border-radius: 10px; border: 1px solid #e4e4e4; background: white; font-size: 0.85rem; cursor: pointer; color: #929292; }
    .logout-btn:hover { border-color: #e53e3e; color: #e53e3e; }

    @media (max-width: 768px) {
      td, th { padding: 10px 12px; font-size: 0.8rem; }
      .msg-preview { max-width: 150px; }
    }
  </style>
</head>
<body>

  <!-- Login -->
  <div class="login-wrap" id="login-section">
    <div class="login-card">
      <h1>Dashboard</h1>
      <p>Accedi per visualizzare i contatti ricevuti.</p>
      <div class="login-error" id="login-error">Password errata</div>
      <form id="login-form">
        <input type="password" name="password" placeholder="Password" autofocus />
        <button type="submit">Accedi</button>
      </form>
    </div>
  </div>

  <!-- Dashboard -->
  <div class="dashboard" id="dashboard-section">
    <div class="dash-header">
      <h1>Contatti ricevuti</h1>
      <div style="display:flex; gap:12px; align-items:center;">
        <div class="dash-tabs">
          <button class="dash-tab active" data-tipo="">Tutti</button>
          <button class="dash-tab" data-tipo="Contatto">Contatti</button>
          <button class="dash-tab" data-tipo="Newsletter">Newsletter</button>
        </div>
        <button class="logout-btn" id="logout-btn">Esci</button>
      </div>
    </div>

    <div class="stats" id="stats">
      <div class="stat-card"><div class="label">Totali</div><div class="value" id="stat-total">—</div></div>
      <div class="stat-card"><div class="label">Contatti</div><div class="value" id="stat-contatti">—</div></div>
      <div class="stat-card"><div class="label">Newsletter</div><div class="value" id="stat-newsletter">—</div></div>
      <div class="stat-card"><div class="label">Da leggere</div><div class="value" id="stat-unread">—</div></div>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Stato</th>
            <th>Tipo</th>
            <th>Nome</th>
            <th>Email</th>
            <th>Telefono</th>
            <th>Messaggio</th>
            <th>Data</th>
          </tr>
        </thead>
        <tbody id="table-body">
          <tr><td colspan="7" class="empty">Caricamento...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <script>
    const loginSection = document.getElementById("login-section");
    const dashSection = document.getElementById("dashboard-section");
    const loginForm = document.getElementById("login-form");
    const loginError = document.getElementById("login-error");
    const tableBody = document.getElementById("table-body");

    // Login
    loginForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      const fd = new FormData(loginForm);
      const res = await fetch("/api/dashboard", { method: "POST", body: fd });
      if (res.ok) {
        loginSection.style.display = "none";
        dashSection.style.display = "block";
        loadData("");
      } else {
        loginError.style.display = "block";
      }
    });

    // Check if already logged in
    fetch("/api/dashboard").then(r => {
      if (r.ok) {
        loginSection.style.display = "none";
        dashSection.style.display = "block";
        loadData("");
      }
    });

    // Tabs
    document.querySelectorAll(".dash-tab").forEach(tab => {
      tab.addEventListener("click", () => {
        document.querySelectorAll(".dash-tab").forEach(t => t.classList.remove("active"));
        tab.classList.add("active");
        loadData(tab.dataset.tipo);
      });
    });

    // Logout
    document.getElementById("logout-btn").addEventListener("click", () => {
      document.cookie = "dash_auth=; Path=/; Max-Age=0";
      loginSection.style.display = "flex";
      dashSection.style.display = "none";
    });

    async function loadData(tipo) {
      const params = tipo ? `?tipo=${tipo}` : "";
      const res = await fetch(`/api/dashboard${params}`);
      if (!res.ok) return;
      const data = await res.json();
      const records = data.records || [];

      // Stats (always from all records)
      if (!tipo) {
        const contatti = records.filter(r => r.fields.Tipo === "Contatto").length;
        const newsletter = records.filter(r => r.fields.Tipo === "Newsletter").length;
        const unread = records.filter(r => !r.fields.Letto).length;
        document.getElementById("stat-total").textContent = records.length;
        document.getElementById("stat-contatti").textContent = contatti;
        document.getElementById("stat-newsletter").textContent = newsletter;
        document.getElementById("stat-unread").textContent = unread;
      }

      if (records.length === 0) {
        tableBody.innerHTML = '<tr><td colspan="7" class="empty">Nessun contatto ricevuto</td></tr>';
        return;
      }

      tableBody.innerHTML = records.map(r => {
        const f = r.fields;
        const isRead = f.Letto;
        const tipo = f.Tipo || "—";
        const date = f.Data ? new Date(f.Data).toLocaleDateString("it-IT", { day: "2-digit", month: "short", year: "numeric", hour: "2-digit", minute: "2-digit" }) : "—";
        return `<tr>
          <td>${isRead ? "✓" : '<span class="badge badge-unread">Nuovo</span>'}</td>
          <td><span class="badge ${tipo === "Newsletter" ? "badge-newsletter" : "badge-contatto"}">${tipo}</span></td>
          <td><strong>${f.Nome || "—"}</strong></td>
          <td>${f.Email || "—"}</td>
          <td>${f.Telefono || "—"}</td>
          <td><div class="msg-preview">${f.Messaggio || "—"}</div></td>
          <td style="white-space:nowrap">${date}</td>
        </tr>`;
      }).join("");
    }
  </script>
</body>
</html>
