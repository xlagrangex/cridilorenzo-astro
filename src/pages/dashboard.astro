---
export const prerender = false;
---
<!doctype html>
<html lang="it">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Dashboard — Christian DiLorenzo</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: "DM Sans", system-ui, sans-serif; background: #f4f2ee; color: #15141a; min-height: 100vh; }

    .login-wrap { display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 20px; }
    .login-card { background: white; border-radius: 20px; padding: 40px; max-width: 380px; width: 100%; box-shadow: 0 4px 24px rgba(0,0,0,0.06); }
    .login-card h1 { font-size: 1.5rem; font-weight: 500; margin-bottom: 8px; }
    .login-card p { color: #3e3e3e; font-size: 0.9rem; margin-bottom: 24px; }
    .login-card input { width: 100%; padding: 12px 16px; border: 1px solid #e4e4e4; border-radius: 10px; font-size: 1rem; margin-bottom: 16px; background: #f4f2ee; }
    .login-card input:focus { outline: none; border-color: #2a9d8f; }
    .login-card button { width: 100%; padding: 14px; background: #2a9d8f; color: white; border: none; border-radius: 12px; font-size: 1rem; font-weight: 600; cursor: pointer; }
    .login-card button:hover { background: #238b7f; }
    .login-error { color: #e53e3e; font-size: 0.85rem; margin-bottom: 12px; display: none; }

    .dashboard { display: none; max-width: 1200px; margin: 0 auto; padding: 24px; }
    .dash-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 32px; flex-wrap: wrap; gap: 16px; }
    .dash-header h1 { font-size: 1.75rem; font-weight: 500; }
    .dash-tabs { display: flex; gap: 8px; }
    .dash-tab { padding: 8px 20px; border-radius: 10px; border: 1px solid #e4e4e4; background: white; font-size: 0.9rem; cursor: pointer; font-weight: 500; transition: all 0.2s; }
    .dash-tab:hover { border-color: #2a9d8f; }
    .dash-tab.active { background: #2a9d8f; color: white; border-color: #2a9d8f; }

    .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 32px; }
    .stat-card { background: white; border-radius: 15px; padding: 20px; }
    .stat-card .label { font-size: 0.8rem; color: #929292; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px; }
    .stat-card .value { font-size: 2rem; font-weight: 600; color: #2a9d8f; }

    .table-wrap { background: white; border-radius: 15px; overflow: hidden; }
    table { width: 100%; border-collapse: collapse; }
    th { text-align: left; padding: 14px 20px; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: #929292; border-bottom: 1px solid #e4e4e4; font-weight: 500; }
    td { padding: 14px 20px; border-bottom: 1px solid #f4f2ee; font-size: 0.9rem; vertical-align: top; }
    tr:last-child td { border-bottom: none; }
    tr:hover { background: #faf9f7; }
    .badge { display: inline-block; padding: 3px 10px; border-radius: 6px; font-size: 0.75rem; font-weight: 600; }
    .badge-contatto { background: #2a9d8f20; color: #2a9d8f; }
    .badge-newsletter { background: #9eaafa30; color: #6366f1; }
    .badge-unread { background: #fef3c7; color: #d97706; }
    .msg-preview { max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: #3e3e3e; }
    .empty { padding: 60px 20px; text-align: center; color: #929292; }

    .logout-btn { padding: 8px 16px; border-radius: 10px; border: 1px solid #e4e4e4; background: white; font-size: 0.85rem; cursor: pointer; color: #929292; }
    .logout-btn:hover { border-color: #e53e3e; color: #e53e3e; }

    @media (max-width: 768px) {
      td, th { padding: 10px 12px; font-size: 0.8rem; }
      .msg-preview { max-width: 150px; }
    }
  </style>
</head>
<body>

  <!-- Login -->
  <div class="login-wrap" id="login-section">
    <div class="login-card">
      <h1>Dashboard</h1>
      <p>Accedi per visualizzare i contatti ricevuti.</p>
      <div class="login-error" id="login-error">Password errata</div>
      <form id="login-form">
        <input type="password" name="password" placeholder="Password" autofocus />
        <button type="submit">Accedi</button>
      </form>
    </div>
  </div>

  <!-- Dashboard -->
  <div class="dashboard" id="dashboard-section">
    <!-- Nav principale -->
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px; flex-wrap:wrap; gap:12px;">
      <div style="display:flex; gap:8px;">
        <button class="dash-tab active" id="nav-contatti" onclick="showSection('contatti')">Contatti</button>
        <button class="dash-tab" id="nav-blog" onclick="showSection('blog')">Blog</button>
      </div>
      <button class="logout-btn" id="logout-btn">Esci</button>
    </div>

    <!-- SEZIONE CONTATTI -->
    <div id="section-contatti">
    <div class="dash-header">
      <h1>Contatti ricevuti</h1>
      <div class="dash-tabs">
        <button class="dash-tab active" data-tipo="">Tutti</button>
        <button class="dash-tab" data-tipo="Contatto">Contatti</button>
        <button class="dash-tab" data-tipo="Newsletter">Newsletter</button>
      </div>
    </div>

    <div class="stats" id="stats">
      <div class="stat-card"><div class="label">Totali</div><div class="value" id="stat-total">—</div></div>
      <div class="stat-card"><div class="label">Contatti</div><div class="value" id="stat-contatti">—</div></div>
      <div class="stat-card"><div class="label">Newsletter</div><div class="value" id="stat-newsletter">—</div></div>
      <div class="stat-card"><div class="label">Da leggere</div><div class="value" id="stat-unread">—</div></div>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Stato</th>
            <th>Tipo</th>
            <th>Nome</th>
            <th>Email</th>
            <th>Telefono</th>
            <th>Messaggio</th>
            <th>Data</th>
          </tr>
        </thead>
        <tbody id="table-body">
          <tr><td colspan="7" class="empty">Caricamento...</td></tr>
        </tbody>
      </table>
    </div>
    </div><!-- /section-contatti -->

    <!-- SEZIONE BLOG -->
    <div id="section-blog" style="display:none;">
      <div class="dash-header">
        <h1>Gestione Blog</h1>
        <button class="dash-tab" onclick="showEditor()" style="background:#2a9d8f;color:white;border-color:#2a9d8f;">+ Nuovo articolo</button>
      </div>

      <!-- Lista post -->
      <div id="blog-list" class="table-wrap">
        <table>
          <thead><tr><th>Titolo</th><th>Data</th><th>Stato</th><th>Azioni</th></tr></thead>
          <tbody id="blog-table-body"><tr><td colspan="4" class="empty">Caricamento...</td></tr></tbody>
        </table>
      </div>

      <!-- Editor -->
      <div id="blog-editor" style="display:none;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
          <h2 style="font-size:1.25rem;" id="editor-title-label">Nuovo articolo</h2>
          <button class="logout-btn" onclick="hideEditor()">← Torna alla lista</button>
        </div>
        <div style="display:flex;flex-direction:column;gap:12px;">
          <input id="ed-title" placeholder="Titolo dell'articolo" style="padding:12px 16px;border:1px solid #e4e4e4;border-radius:10px;font-size:1rem;background:white;">
          <input id="ed-desc" placeholder="Descrizione SEO (150-160 caratteri)" style="padding:12px 16px;border:1px solid #e4e4e4;border-radius:10px;font-size:0.9rem;background:white;">
          <div style="display:flex;gap:12px;">
            <input id="ed-date" type="date" style="padding:10px 14px;border:1px solid #e4e4e4;border-radius:10px;font-size:0.9rem;background:white;flex:1;">
            <input id="ed-tags" placeholder="Tag (separati da virgola)" style="padding:10px 14px;border:1px solid #e4e4e4;border-radius:10px;font-size:0.9rem;background:white;flex:2;">
          </div>
          <div style="display:flex;align-items:center;gap:8px;">
            <input id="ed-draft" type="checkbox"><label for="ed-draft" style="font-size:0.85rem;color:#929292;">Bozza (non pubblicare)</label>
          </div>
          <textarea id="ed-body" placeholder="Contenuto dell'articolo (Markdown)&#10;&#10;Usa ## per i titoli delle sezioni&#10;Usa **grassetto** per enfatizzare&#10;Usa > per le citazioni" style="padding:16px;border:1px solid #e4e4e4;border-radius:10px;font-size:0.9rem;min-height:400px;font-family:monospace;line-height:1.6;background:white;resize:vertical;"></textarea>
          <div style="display:flex;gap:12px;">
            <button onclick="savePost()" style="flex:1;padding:14px;background:#2a9d8f;color:white;border:none;border-radius:12px;font-size:1rem;font-weight:600;cursor:pointer;">Pubblica</button>
          </div>
        </div>
        <input type="hidden" id="ed-slug">
        <input type="hidden" id="ed-sha">
      </div>
    </div><!-- /section-blog -->
  </div>

  <script is:inline>
    const loginSection = document.getElementById("login-section");
    const dashSection = document.getElementById("dashboard-section");
    const loginForm = document.getElementById("login-form");
    const loginError = document.getElementById("login-error");
    const tableBody = document.getElementById("table-body");

    // Login
    loginForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      const fd = new FormData(loginForm);
      const res = await fetch("/api/dashboard", { method: "POST", headers: {"Content-Type":"application/json"}, body: JSON.stringify({password: fd.get("password")}) });
      if (res.ok) {
        loginSection.style.display = "none";
        dashSection.style.display = "block";
        loadData("");
      } else {
        loginError.style.display = "block";
      }
    });

    // Check if already logged in
    fetch("/api/dashboard").then(r => {
      if (r.ok) {
        loginSection.style.display = "none";
        dashSection.style.display = "block";
        loadData("");
      }
    });

    // Tabs
    document.querySelectorAll(".dash-tab").forEach(tab => {
      tab.addEventListener("click", () => {
        document.querySelectorAll(".dash-tab").forEach(t => t.classList.remove("active"));
        tab.classList.add("active");
        loadData(tab.dataset.tipo);
      });
    });

    // Logout
    document.getElementById("logout-btn").addEventListener("click", () => {
      document.cookie = "dash_auth=; Path=/; Max-Age=0";
      loginSection.style.display = "flex";
      dashSection.style.display = "none";
    });

    async function loadData(tipo) {
      const params = tipo ? `?tipo=${tipo}` : "";
      const res = await fetch(`/api/dashboard${params}`);
      if (!res.ok) return;
      const data = await res.json();
      const records = data.records || [];

      // Stats (always from all records)
      if (!tipo) {
        const contatti = records.filter(r => r.fields.Tipo === "Contatto").length;
        const newsletter = records.filter(r => r.fields.Tipo === "Newsletter").length;
        const unread = records.filter(r => !r.fields.Letto).length;
        document.getElementById("stat-total").textContent = records.length;
        document.getElementById("stat-contatti").textContent = contatti;
        document.getElementById("stat-newsletter").textContent = newsletter;
        document.getElementById("stat-unread").textContent = unread;
      }

      if (records.length === 0) {
        tableBody.innerHTML = '<tr><td colspan="7" class="empty">Nessun contatto ricevuto</td></tr>';
        return;
      }

      tableBody.innerHTML = records.map(r => {
        const f = r.fields;
        const isRead = f.Letto;
        const tipo = f.Tipo || "—";
        const date = f.Data ? new Date(f.Data).toLocaleDateString("it-IT", { day: "2-digit", month: "short", year: "numeric", hour: "2-digit", minute: "2-digit" }) : "—";
        return `<tr>
          <td>${isRead ? "✓" : '<span class="badge badge-unread">Nuovo</span>'}</td>
          <td><span class="badge ${tipo === "Newsletter" ? "badge-newsletter" : "badge-contatto"}">${tipo}</span></td>
          <td><strong>${f.Nome || "—"}</strong></td>
          <td>${f.Email || "—"}</td>
          <td>${f.Telefono || "—"}</td>
          <td><div class="msg-preview">${f.Messaggio || "—"}</div></td>
          <td style="white-space:nowrap">${date}</td>
        </tr>`;
      }).join("");
    }

    // ===== BLOG =====
    function showSection(s) {
      document.getElementById("section-contatti").style.display = s === "contatti" ? "block" : "none";
      document.getElementById("section-blog").style.display = s === "blog" ? "block" : "none";
      document.getElementById("nav-contatti").classList.toggle("active", s === "contatti");
      document.getElementById("nav-blog").classList.toggle("active", s === "blog");
      if (s === "blog") loadBlog();
    }

    function showEditor(post) {
      document.getElementById("blog-list").style.display = "none";
      document.getElementById("blog-editor").style.display = "block";
      if (post) {
        document.getElementById("editor-title-label").textContent = "Modifica articolo";
        document.getElementById("ed-title").value = post.frontmatter.title || "";
        document.getElementById("ed-desc").value = post.frontmatter.description || "";
        document.getElementById("ed-date").value = post.frontmatter.date || "";
        document.getElementById("ed-tags").value = (post.frontmatter.tags || "").replace(/[\[\]"]/g, "");
        document.getElementById("ed-draft").checked = post.draft;
        document.getElementById("ed-body").value = post.body || "";
        document.getElementById("ed-slug").value = post.slug;
        document.getElementById("ed-sha").value = post.sha;
      } else {
        document.getElementById("editor-title-label").textContent = "Nuovo articolo";
        document.getElementById("ed-title").value = "";
        document.getElementById("ed-desc").value = "";
        document.getElementById("ed-date").value = new Date().toISOString().split("T")[0];
        document.getElementById("ed-tags").value = "";
        document.getElementById("ed-draft").checked = false;
        document.getElementById("ed-body").value = "";
        document.getElementById("ed-slug").value = "";
        document.getElementById("ed-sha").value = "";
      }
    }

    function hideEditor() {
      document.getElementById("blog-list").style.display = "block";
      document.getElementById("blog-editor").style.display = "none";
      loadBlog();
    }

    var blogPosts = [];

    async function loadBlog() {
      var res = await fetch("/api/blog");
      if (!res.ok) return;
      var data = await res.json();
      blogPosts = data.posts || [];
      var tb = document.getElementById("blog-table-body");

      if (blogPosts.length === 0) {
        tb.innerHTML = '<tr><td colspan="4" class="empty">Nessun articolo</td></tr>';
        return;
      }

      tb.innerHTML = blogPosts.map(function(p, i) {
        var date = p.date ? new Date(p.date).toLocaleDateString("it-IT", {day:"2-digit",month:"short",year:"numeric"}) : "—";
        return '<tr>' +
          '<td><strong>' + (p.title || "—") + '</strong></td>' +
          '<td style="white-space:nowrap">' + date + '</td>' +
          '<td>' + (p.draft ? '<span class="badge badge-unread">Bozza</span>' : '<span class="badge badge-contatto">Pubblicato</span>') + '</td>' +
          '<td><button onclick="editPost(' + i + ')" style="padding:4px 12px;border:1px solid #e4e4e4;border-radius:6px;background:white;cursor:pointer;font-size:0.8rem;margin-right:4px;">Modifica</button>' +
          '<button onclick="deletePost(' + i + ')" style="padding:4px 12px;border:1px solid #e4e4e4;border-radius:6px;background:white;cursor:pointer;font-size:0.8rem;color:#e53e3e;">Elimina</button></td>' +
          '</tr>';
      }).join("");
    }

    function editPost(i) { showEditor(blogPosts[i]); }

    async function deletePost(i) {
      if (!confirm("Sei sicuro di voler eliminare questo articolo?")) return;
      var p = blogPosts[i];
      await fetch("/api/blog", {
        method: "DELETE",
        headers: {"Content-Type":"application/json"},
        body: JSON.stringify({filename: p.filename, sha: p.sha})
      });
      loadBlog();
    }

    async function savePost() {
      var btn = document.querySelector('#blog-editor button[onclick="savePost()"]');
      btn.textContent = "Salvataggio...";
      btn.disabled = true;

      var res = await fetch("/api/blog", {
        method: "POST",
        headers: {"Content-Type":"application/json"},
        body: JSON.stringify({
          title: document.getElementById("ed-title").value,
          description: document.getElementById("ed-desc").value,
          date: document.getElementById("ed-date").value,
          tags: document.getElementById("ed-tags").value,
          draft: document.getElementById("ed-draft").checked,
          body: document.getElementById("ed-body").value,
          slug: document.getElementById("ed-slug").value,
          sha: document.getElementById("ed-sha").value,
        })
      });

      btn.textContent = "Pubblica";
      btn.disabled = false;

      if (res.ok) {
        alert("Articolo salvato! Il sito si aggiornerà in 1-2 minuti.");
        hideEditor();
      } else {
        alert("Errore nel salvataggio.");
      }
    }
  </script>
</body>
</html>
