---
import Layout from "../layouts/Layout.astro";
import FaqAccordion from "../components/react/FaqAccordion.tsx";
import RainbowButton from "../components/react/RainbowButton.tsx";
import {
  getHomepage,
  getSiteSettings,
  isVisible,
  pick,
  sanityImageUrl,
} from "../lib/sanity";

const [homepage, settings] = await Promise.all([
  getHomepage(),
  getSiteSettings(),
]);

const defaultCalendarUrl = "https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ0hE4rG_WwpeS2ck-0o1mnjaoGD6FtqZjcZZgwkNXOB7dSspKlguUEIV4RFzX8DBvZz3v8NjktC";
const calendarUrl = pick(settings?.calendarUrl, defaultCalendarUrl);
const contactEmail = pick(settings?.email, "info@cridilorenzo.com");
const contactPhone = pick(settings?.phone, "+39 347 330 1278");
const contactPhoneRaw = contactPhone.replace(/\s+/g, "");

const serviziFallback = [
  { title: "Affrontare rapporti conflittuali", desc: "Difficoltà di coppia, in famiglia o nelle relazioni importanti.", image: "/images/affrontare-rapporti.webp" },
  { title: "Rompere schemi e blocchi interiori", desc: "Quei meccanismi che si ripetono e ti fanno sentire fermo o intrappolato.", image: "/images/rompere-schemi.webp" },
  { title: "Crescita personale", desc: "Quando senti che è il momento di capirti più a fondo e fare un passo avanti nella tua vita.", image: "/images/crescita-personale.webp" },
  { title: "Aumentare la consapevolezza di te", desc: "Comprendere emozioni, reazioni, bisogni e parti di te che restano spesso in secondo piano.", image: "/images/consapevolezza-di-se.webp" },
  { title: "Gestire ansia, stress e paure", desc: "Quando il peso emotivo diventa difficile da sostenere da soli.", image: "/images/ansia.webp" },
  { title: "Raggiungere nuovi obiettivi personali", desc: "Quando vuoi cambiare qualcosa ma ti senti bloccato o confuso.", image: "/images/goal.webp" },
  { title: "Ritrovare te stesso", desc: "Nei momenti in cui ti senti distante da ciò che sei davvero.", image: "/images/ritrovare-se-stessi.webp" },
  { title: "Attraversare una perdita o un distacco", desc: "La fine di una relazione, un cambiamento importante, un lutto.", image: "/images/attraversare-una-perdita.webp" },
];

const percheScegliermiFallback = [
  { title: "Ho attraversato il mio cammino interiore", desc: "Prima di accompagnare gli altri, ho attraversato il mio percorso personale, chiamato \"opera al nero\": anni di lavoro interiore e confronto con le mie ombre.", icon: "/images/icons/compass.svg" },
  { title: "Un lavoro profondo sui sogni", desc: "Integro l'interpretazione dei sogni secondo l'approccio di Gabriella Tupini, uno strumento prezioso per accedere ai contenuti inconsci.", icon: "/images/icons/moon-star.svg" },
  { title: "Nessuna lente ideologica", desc: "Non porto credenze religiose o filosofiche nel percorso. Lo spazio che costruisco è neutro, aperto, libero.", icon: "/images/icons/scale.svg" },
  { title: "Un percorso costruito insieme", desc: "Ogni cammino nasce dall'ascolto autentico e si costruisce passo dopo passo, rispettando la tua storia, le tue relazioni e il tuo tempo.", icon: "/images/icons/heart.svg" },
  { title: "Oltre gli schemi mentali", desc: "Ho lavorato per sciogliere condizionamenti e automatismi della mente. Questo mi consente di ascoltare davvero.", icon: "/images/icons/waves.svg" },
];

const strumentiFallback = [
  { num: "1", title: "Interpretazione dei sogni", desc: "I sogni parlano attraverso immagini e simboli. Aiutano a comprendere emozioni profonde, parti nascoste di noi e schemi che si ripetono.", icon: "/images/Crescent-Moon_1Crescent-Moon.png" },
  { num: "2", title: "Genogramma", desc: "Una mappa della storia familiare che aiuta a riconoscere dinamiche e schemi relazionali che influenzano il presente.", icon: "/images/Puzzle_1Puzzle.png" },
  { num: "3", title: "Costellazioni familiari", desc: "Permettono di osservare le dinamiche relazionali e familiari che influenzano il presente, per ritrovare il proprio posto con più chiarezza.", icon: "/images/Oak-Tree_1Oak-Tree.png" },
  { num: "4", title: "Scrittura espressiva e di consapevolezza", desc: "La scrittura può diventare uno spazio di ascolto interiore, per dare forma a emozioni, immagini e vissuti.", icon: "/images/Autograph_1Autograph.png" },
];

const diCosaMiOccupoFallback = [
  { title: "Percorso di Counseling", desc: "Uno spazio di ascolto e accompagnamento per fare chiarezza, comprendere ciò che stai vivendo e ritrovare una direzione più autentica.", image: "/images/Why-Chose-Img-01_1Why-Chose-Img-01.avif" },
  { title: "Interpretazione dei Sogni", desc: "I sogni come linguaggio simbolico dell'inconscio: uno strumento prezioso per esplorare parti profonde di te.", image: "/images/interpretazione-sogni-psicoterapia-centro-psicologia-lecco-1.png" },
  { title: "Supporto relazioni e autostima", desc: "Un accompagnamento per riconoscere schemi relazionali, rafforzare l'autostima e costruire rapporti più consapevoli.", image: "/images/counseling-1500x430-1.png" },
];

const comeFunzionaStepsFallback = [
  { label: "Passo 1", title: "Prenota il colloquio conoscitivo gratuito", price: "Gratuito", priceSuffix: "", details: "Prenota un <strong>incontro gratuito di 45 minuti</strong> per conoscerci, comprendere la tua situazione e ascoltare le tue esigenze.", bulletPoints: [], highlighted: false },
  { label: "Passo 2", title: "Ricevi una proposta per il tuo percorso", price: "Gratuita", priceSuffix: "", details: "Ti sarà inviata una <strong>sintesi</strong> di ciò che è emerso nel <strong>nostro incontro</strong>, insieme a una proposta di percorso e ai primi strumenti che potremo utilizzare.", bulletPoints: [], highlighted: false },
  {
    label: "Continuiamo",
    title: "Ogni incontro successivo",
    price: "70€",
    priceSuffix: "/ 45 min",
    details: "Online, con cadenza da concordare insieme.",
    bulletPoints: [
      "Ascolto, dialogo e strumenti dedicati",
      "Interpretazione dei sogni inclusa",
      "Nessun vincolo di durata minima",
      "Puoi interrompere in qualsiasi momento",
      "Riservatezza totale garantita",
    ],
    highlighted: true,
  },
];

const psicologoItemsFallback = [
  "Si occupa di diagnosi e trattamento di disturbi psicologici",
  "Lavora in ambito clinico e sanitario",
  "Utilizza strumenti terapeutici e protocolli specifici",
  "Indicato in presenza di sintomi strutturati o sofferenza clinica",
  "Percorsi regolamentati e orientati alla cura",
];

const counselorItemsFallback = [
  { text: 'Offre uno spazio di <strong class="text-white">ascolto e accompagnamento</strong> non clinico', detail: "Un luogo sicuro dove portare ciò che senti — confusione, stanchezza, emozioni che pesano — senza dover dimostrare nulla." },
  { text: 'Lavora su <strong class="text-white">consapevolezza</strong>, <strong class="text-white">crescita personale</strong> e orientamento', detail: "Non si tratta di 'aggiustare' qualcosa, ma di fare chiarezza, dare un nome a ciò che si muove dentro e ritrovare la propria direzione." },
  { text: 'Aiuta a <strong class="text-white">comprendere</strong> schemi e <strong class="text-white">blocchi emotivi</strong>', detail: "Schemi che si ripetono nelle relazioni, nel lavoro, nelle scelte. Insieme esploriamo da dove vengono e come trasformarli." },
  { text: 'Si rivolge a persone che desiderano conoscersi meglio', detail: "Non serve avere un problema specifico. Basta sentire che è arrivato il momento di fermarsi e guardarsi dentro con onestà." },
  { text: 'Percorsi orientati all\'equilibrio e alle scelte personali', detail: "Ogni percorso è unico, costruito passo dopo passo, rispettando la tua storia, i tuoi tempi e i tuoi bisogni." },
];

const marqueeFallback = [
  { iconKey: "clock", strong: "45 min", label: "durata incontro", highlight: false },
  { iconKey: "screen", strong: "Online", label: "completamente", highlight: false },
  { iconKey: "wallet", strong: "70€", label: "a incontro", highlight: false },
  { iconKey: "shield", strong: "100%", label: "riservatezza", highlight: false },
  { iconKey: "gift", strong: "Primo colloquio", label: "gratuito", highlight: true },
];

const h = homepage || {};

const hero = {
  headingTop: pick(h.hero?.headingTop, "Uno spazio per"),
  headingItalic: pick(h.hero?.headingItalic, "fermarti e fare chiarezza"),
  body: pick(h.hero?.body, "Se stai vivendo un periodo di difficoltà, cambiamento o smarrimento, possiamo lavorarci insieme. Gli incontri sono <strong>un tempo dedicato a te</strong>, per comprendere meglio ciò che accade dentro e trasformarlo in <strong>consapevolezza, benessere ed equilibrio</strong>."),
  primaryCta: pick(h.hero?.primaryCtaLabel, "Prenota un colloquio gratuito"),
  secondaryCta: pick(h.hero?.secondaryCtaLabel, "Chi sono"),
  image: sanityImageUrl(h.hero?.heroImage, "/images/christian-hero-section.webp"),
  ratingTitle: pick(h.hero?.ratingTitle, "4.9/5 Soddisfazione clienti"),
  ratingDesc: pick(h.hero?.ratingDescription, "Scopri cosa raccontano le persone che hanno intrapreso questo percorso."),
};

const chiSono = {
  tags: pick(h.chiSono?.tags, ["Chi sono", "counselor professionista"]),
  heading: pick(h.chiSono?.heading, "Ciao, sono Christian"),
  body1: pick(h.chiSono?.body1, "Sono una persona che ha imparato, nel tempo, a <strong>fermarsi e ad ascoltarsi davvero</strong>. E oggi faccio questo anche con gli altri.<br><br>Sono counselor e accompagno le persone in uno <strong>spazio di ascolto</strong> e di <strong>esplorazione interiore</strong>, principalmente online.<br>Un luogo semplice, umano, dove poter portare ciò che si sente — <strong>confusione, stanchezza, emozioni che pesano, momenti di blocco</strong> — senza dover dimostrare nulla.<br><br>Il mio modo di lavorare nasce dal mio <strong>percorso personale</strong>.<br>So cosa significa sentirsi lontani da sé, non capirsi, vivere <strong>schemi che sembrano ripetersi</strong>."),
  body2: pick(h.chiSono?.body2, "So quanto può fare la differenza incontrare qualcuno che ti aiuta a guardarti dentro con <strong>rispetto e senza giudizio</strong>.<br><br>Uno degli strumenti che utilizzo è l'<strong>interpretazione dei sogni</strong>, perché i sogni parlano di noi in modo sincero e profondo.<br>A volte mostrano parti che durante il giorno non riusciamo a vedere, ma che hanno molto da dire sulla nostra vita, sulle nostre ferite e anche sulle nostre risorse.<br><br>Negli incontri non si tratta di \"aggiustare\" qualcosa, ma di <strong>incontrarsi</strong>, fare chiarezza, dare un nome a ciò che si muove dentro e <strong>ritrovare un po' più di spazio, respiro e libertà</strong> nel proprio modo di vivere."),
  image1: sanityImageUrl(h.chiSono?.image1, "/images/studio-da-councelor.webp"),
  image2: sanityImageUrl(h.chiSono?.image2, "/images/chi-sono_.webp"),
  ctaLabel: pick(h.chiSono?.ctaLabel, "Prenota un colloquio gratuito"),
};

const servizi = {
  subtitle: pick(h.servizi?.subtitle, "[ DI COSA MI OCCUPO ]"),
  headingStart: pick(h.servizi?.headingStart, "In cosa posso"),
  headingItalic: pick(h.servizi?.headingItalic, "accompagnarti"),
  body: pick(h.servizi?.body, "Ti accompagno quando senti che dentro qualcosa chiede attenzione, ma non sai bene da dove iniziare. Posso esserti accanto per:"),
  items: (h.servizi?.items && h.servizi.items.length > 0
    ? h.servizi.items.map((s) => ({
        title: s.title || "",
        desc: s.desc || "",
        image: sanityImageUrl(s.image, "/images/affrontare-rapporti.webp"),
      }))
    : serviziFallback),
  conclusion: pick(h.servizi?.conclusion, "Ogni percorso è uno spazio di ascolto e di comprensione, dove ciò che senti ha valore e può trovare un significato."),
  ctaLabel: pick(h.servizi?.ctaLabel, "Prenota un colloquio gratuito"),
};

const comeFunziona = {
  subtitle: pick(h.comeFunziona?.subtitle, "[ COME FUNZIONA ]"),
  headingStart: pick(h.comeFunziona?.headingStart, "Un percorso"),
  headingItalic: pick(h.comeFunziona?.headingItalic, "chiaro e trasparente"),
  body: pick(h.comeFunziona?.body, "Dal primo contatto gratuito all'accompagnamento nel tempo, ogni passo è pensato per offrirti ascolto autentico e un sostegno costante."),
  image: sanityImageUrl(h.comeFunziona?.image, "/images/councelor.webp"),
  stepsHeadingStart: pick(h.comeFunziona?.stepsHeadingStart, "Il percorso"),
  stepsHeadingItalic: pick(h.comeFunziona?.stepsHeadingItalic, "individuale"),
  stepsIntro: pick(h.comeFunziona?.stepsIntro, "Nessun pacchetto obbligatorio. Paghi solo gli incontri che fai, senza vincoli."),
  steps: (h.comeFunziona?.steps && h.comeFunziona.steps.length > 0
    ? h.comeFunziona.steps.map((s) => ({
        label: s.label || "",
        title: s.title || "",
        price: s.price || "",
        priceSuffix: s.priceSuffix || "",
        details: s.details || "",
        bulletPoints: s.bulletPoints || [],
        highlighted: !!s.highlighted,
      }))
    : comeFunzionaStepsFallback),
  ctaLabel: pick(h.comeFunziona?.ctaLabel, "Prenota un colloquio gratuito"),
};

const perche = {
  subtitle: pick(h.perche?.subtitle, "[ CHI SCEGLIERE ]"),
  heading: pick(h.perche?.heading, "Perché scegliere me"),
  body: pick(h.perche?.body, "Scegliere qualcuno con cui intraprendere un percorso interiore è una decisione delicata. Al di là dei titoli, ci sono qualità umane e professionali fondamentali."),
  items: (h.perche?.items && h.perche.items.length > 0
    ? h.perche.items.map((s) => ({
        title: s.title || "",
        desc: s.desc || "",
        icon: sanityImageUrl(s.icon, "/images/Compass_1Compass.png"),
      }))
    : percheScegliermiFallback),
};

const diCosaMiOccupo = {
  subtitle: pick(h.diCosaMiOccupo?.subtitle, "[ DI COSA MI OCCUPO ]"),
  headingStart: pick(h.diCosaMiOccupo?.headingStart, "Ti accompagno in percorsi di"),
  headingItalic: pick(h.diCosaMiOccupo?.headingItalic, "consapevolezza e crescita personale"),
  items: (h.diCosaMiOccupo?.items && h.diCosaMiOccupo.items.length > 0
    ? h.diCosaMiOccupo.items.map((s) => ({
        title: s.title || "",
        desc: s.desc || "",
        image: sanityImageUrl(s.image, "/images/Why-Chose-Img-01_1Why-Chose-Img-01.avif"),
      }))
    : diCosaMiOccupoFallback),
};

const strumenti = {
  subtitle: pick(h.strumenti?.subtitle, "[ STRUMENTI ]"),
  headingStart: pick(h.strumenti?.headingStart, "Gli strumenti"),
  headingItalic: pick(h.strumenti?.headingItalic, "del percorso"),
  body: pick(h.strumenti?.body, "Non esistono tecniche standard o protocolli rigidi. Ogni persona è diversa, e il lavoro nasce da ciò che porti tu, momento per momento."),
  items: (h.strumenti?.items && h.strumenti.items.length > 0
    ? h.strumenti.items.map((s) => ({
        num: s.num || "",
        title: s.title || "",
        desc: s.desc || "",
        icon: sanityImageUrl(s.icon, "/images/Crescent-Moon_1Crescent-Moon.png"),
      }))
    : strumentiFallback),
  ctaLabel: pick(h.strumenti?.ctaLabel, "Prenota un colloquio gratuito"),
};

const marqueeBase = (h.marquee?.items && h.marquee.items.length > 0
  ? h.marquee.items.map((s) => ({
      iconKey: s.iconKey || "clock",
      strong: s.strong || "",
      label: s.label || "",
      highlight: !!s.highlight,
    }))
  : marqueeFallback);
const marqueeItems = marqueeBase;

const confronto = {
  subtitle: pick(h.confronto?.subtitle, "[ QUALE PERCORSO FA PER TE? ]"),
  headingStart: pick(h.confronto?.headingStart, "Due approcci diversi,"),
  headingItalic: pick(h.confronto?.headingItalic, "lo stesso rispetto"),
  psicologoTitle: pick(h.confronto?.psicologoTitle, "Psicologo"),
  psicologoItems: pick(h.confronto?.psicologoItems, psicologoItemsFallback),
  counselorTitle: pick(h.confronto?.counselorTitle, "Counselor"),
  counselorBadge: pick(h.confronto?.counselorBadge, "Il mio approccio"),
  counselorItems: (h.confronto?.counselorItems && h.confronto.counselorItems.length > 0
    ? h.confronto.counselorItems.map((s) => ({ text: s.text || "", detail: s.detail || "" }))
    : counselorItemsFallback),
  conclusion: pick(h.confronto?.conclusion, "Non sai quale percorso fa per te? Il colloquio conoscitivo gratuito serve esattamente a capire insieme la strada giusta."),
  ctaLabel: pick(h.confronto?.ctaLabel, "Prenota un colloquio gratuito"),
};

const faq = {
  subtitle: pick(h.faq?.subtitle, "[ DOMANDE FREQUENTI ]"),
  headingStart: pick(h.faq?.headingStart, "Hai qualche"),
  headingItalic: pick(h.faq?.headingItalic, "domanda?"),
  items: h.faq?.items && h.faq.items.length > 0
    ? h.faq.items.map((s) => ({ question: s.question || "", answer: s.answer || "" }))
    : [],
};

const contatti = {
  subtitle: pick(h.contatti?.subtitle, "[ CONTATTI ]"),
  headingStart: pick(h.contatti?.headingStart, "Cerchi uno spazio di"),
  headingItalic: pick(h.contatti?.headingItalic, "ascolto?"),
  body: pick(h.contatti?.body, "Se senti il bisogno di fermarti, fare chiarezza o capire se questo percorso fa per te, puoi lasciarmi un messaggio. Ti risponderò con attenzione per capire insieme come iniziare."),
  ctaLabel: pick(h.contatti?.ctaLabel, "Invia il messaggio"),
};
---

<Layout title="Christian Dilorenzo - Counselor">

  {isVisible(h.hero) && (
  <section class="pt-14 md:pt-20 pb-16">
    <div class="wrapper px-4 md:px-8 lg:px-12">
      <div class="mx-auto" data-animate="fade-in-up">
        <div class="flex flex-col lg:flex-row gap-7">
          <div class="group/hero bg-[#f4f2ee] rounded-[20px] relative overflow-hidden w-full px-8 py-12 md:px-16 md:py-16 flex flex-col gap-15">
            <div class="flex flex-col gap-7 max-w-[610px] relative z-[4]">
              <div class="flex flex-col gap-4">
                <h1>{hero.headingTop} <br><span class="italic font-medium">{hero.headingItalic}</span></h1>
                <p class="regular-text opacity-80 !mb-0" set:html={hero.body}></p>
              </div>
              <div class="flex flex-wrap items-center gap-4">
                <RainbowButton href={calendarUrl} client:load>
                  {hero.primaryCta}
                  <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </RainbowButton>
                <a href="#chi-sono" class="btn-secondary group">
                  <span class="inline-flex items-center gap-2">
                    {hero.secondaryCta}
                    <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-y-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                  </span>
                </a>
              </div>
            </div>

            <a href="https://it.trustpilot.com/review/cridilorenzo.com" target="_blank" class="hero-review-card relative z-[4] group transition-all duration-300 hover:shadow-lg hover:-translate-y-1">
              <div class="flex flex-col gap-3">
                <div class="flex items-center gap-3">
                  <img loading="lazy" src="/images/kindpng_7219870.png" alt="Trustpilot" class="h-auto w-[140px] object-contain" />
                  <img src="/images/freccia-destra.svg" loading="lazy" alt="" class="w-4 h-4 opacity-50 transition-transform duration-300 group-hover:translate-x-1" />
                </div>
                <p class="text-[#15141a] text-lg font-medium leading-[156%] m-0">{hero.ratingTitle}</p>
              </div>
              <p class="text-[#373737cc] text-base m-0 transition-colors duration-300 group-hover:text-[#15141a]">{hero.ratingDesc}</p>
            </a>

            <img loading="lazy" src={hero.image} alt="Christian Dilorenzo" class="lg:hidden w-full max-w-[280px] mx-auto mt-4 object-contain" />
            <img loading="lazy" src={hero.image} alt="Christian Dilorenzo" class="hidden lg:block absolute top-0 bottom-0 right-0 z-[1] h-full w-auto object-contain transition-transform duration-700 ease-out group-hover/hero:scale-[1.03]" />
            <div class="hidden lg:block absolute bottom-0 right-0 z-[2] w-[50%] h-[30%] bg-gradient-to-t from-[#f4f2ee] to-transparent pointer-events-none"></div>
          </div>
        </div>
      </div>
    </div>
  </section>
  )}

  {isVisible(h.chiSono) && (
  <section id="chi-sono" class="py-16 md:py-24">
    <div class="wrapper px-4 md:px-8 lg:px-12">
      <div class="grid grid-cols-1 md:grid-cols-[1.1fr_1fr] gap-8 items-center mb-12" data-animate="fade-in-up">
        <div class="relative">
          <div class="aspect-[3/2] overflow-hidden rounded-[20px]">
            <img src={chiSono.image2} alt="Christian" loading="lazy" class="w-full h-full object-cover" />
          </div>
        </div>
        <div class="flex flex-col gap-2.5 max-w-[469px]">
          <div class="flex flex-wrap gap-2">
            {chiSono.tags.map((tag) => <span class="tag-pill">{tag}</span>)}
          </div>
          <h3 class="text-[32px] font-medium text-[#15141a] tracking-tight mb-3">{chiSono.heading}</h3>
          <p class="regular-text !text-base" set:html={chiSono.body1}></p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-[1fr_1.1fr] gap-8 items-center" data-animate="fade-in-up">
        <div class="flex flex-col gap-2.5 max-w-[469px] order-2 md:order-1">
          <p class="regular-text !text-base" set:html={chiSono.body2}></p>
          <a href={calendarUrl} target="_blank" class="btn-primary self-start">{chiSono.ctaLabel}</a>
        </div>
        <div class="relative order-1 md:order-2">
          <div class="aspect-[3/2] overflow-hidden rounded-[20px]">
            <img src={chiSono.image1} alt="Studio" loading="lazy" class="w-full h-full object-cover" />
          </div>
        </div>
      </div>
    </div>
  </section>
  )}

  {isVisible(h.servizi) && (
  <section id="servizi" class="bg-[#f4f2ee] py-16 md:py-20 overflow-hidden">
    <div class="wrapper px-4 md:px-8 lg:px-12">
      <div class="max-w-2xl mb-10" data-animate="fade-in-up">
        <p class="sub-title mb-3">{servizi.subtitle}</p>
        <h2>{servizi.headingStart} <span class="italic">{servizi.headingItalic}</span></h2>
        <p class="regular-text mt-5">{servizi.body}</p>
      </div>

      <div class="flex gap-6 overflow-x-auto pb-4 snap-x snap-mandatory scrollbar-hide" data-animate="fade-in-up">
        {servizi.items.map((s) => (
