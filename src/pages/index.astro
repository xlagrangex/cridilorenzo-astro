            <input type="email" name="email" placeholder="La tua email" required class="contact-field" />
            <input type="tel" name="phone" placeholder="Cellulare / Whatsapp" required class="contact-field" />
            <textarea name="message" placeholder="Raccontami brevemente tutto ciò che può essere utile per preparare il nostro incontro" class="contact-field min-h-[117px] resize-y"></textarea>
            <button type="submit" class="btn-submit w-full">Invia il messaggio</button>
