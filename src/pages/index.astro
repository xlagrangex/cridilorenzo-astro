  import { fadeInUp, staggerIn, drawPathOnScroll } from "../lib/animations";

  document.addEventListener("astro:page-load", () => {
    fadeInUp('[data-animate="fade-in-up"]');
    staggerIn(".perche-card", { stagger: 0.1, y: 36 });
    staggerIn(".strumento-card", { stagger: 0.12, y: 30, trigger: ".strumenti-section" });
    drawPathOnScroll(".strumenti-path-progress", { trigger: ".strumenti-timeline", start: "top 90%", end: "bottom 70%" });
  });
</script>

<script is:inline>
  document.addEventListener("astro:page-load", function() {
    var form = document.getElementById("contact-form");
    if (!form) return;

    form.addEventListener("submit", function(e) {
      e.preventDefault();
      e.stopPropagation();

      var btn = form.querySelector("button[type=submit]");
      var originalText = btn.textContent;
      btn.textContent = "Invio in corso...";
      btn.disabled = true;

      var formData = new FormData(form);
      var jsonData = {};
      formData.forEach(function(value, key) { jsonData[key] = value; });

      fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(jsonData),
      })
      .then(function(res) {
        if (res.ok) {
          form.reset();
          if (window.showToast) window.showToast("Messaggio inviato! Ti risponderò il prima possibile.", "success");
        } else {
          if (window.showToast) window.showToast("Ops, qualcosa non ha funzionato. Riprova.", "error");
        }
      })
      .catch(function() {
        if (window.showToast) window.showToast("Errore di connessione. Riprova.", "error");
      })
      .finally(function() {
        btn.textContent = originalText;
        btn.disabled = false;
      });
    });
  });
</script>
