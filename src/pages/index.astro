---
import Layout from "../layouts/Layout.astro";
import FaqAccordion from "../components/react/FaqAccordion.tsx";
import RainbowButton from "../components/react/RainbowButton.tsx";

const calendarUrl = "https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ0hE4rG_WwpeS2ck-0o1mnjaoGD6FtqZjcZZgwkNXOB7dSspKlguUEIV4RFzX8DBvZz3v8NjktC";

const servizi = [
  { title: "Affrontare rapporti conflittuali", desc: "Difficoltà di coppia, in famiglia o nelle relazioni importanti.", img: "/images/affrontare-rapporti.webp" },
  { title: "Rompere schemi e blocchi interiori", desc: "Quei meccanismi che si ripetono e ti fanno sentire fermo o intrappolato.", img: "/images/rompere-schemi.webp" },
  { title: "Crescita personale", desc: "Quando senti che è il momento di capirti più a fondo e fare un passo avanti nella tua vita.", img: "/images/crescita-personale.webp" },
  { title: "Aumentare la consapevolezza di te", desc: "Comprendere emozioni, reazioni, bisogni e parti di te che restano spesso in secondo piano.", img: "/images/consapevolezza-di-se.webp" },
  { title: "Gestire ansia, stress e paure", desc: "Quando il peso emotivo diventa difficile da sostenere da soli.", img: "/images/ansia.webp" },
  { title: "Raggiungere nuovi obiettivi personali", desc: "Quando vuoi cambiare qualcosa ma ti senti bloccato o confuso.", img: "/images/goal.webp" },
  { title: "Ritrovare te stesso", desc: "Nei momenti in cui ti senti distante da ciò che sei davvero.", img: "/images/ritrovare-se-stessi.webp" },
  { title: "Attraversare una perdita o un distacco", desc: "La fine di una relazione, un cambiamento importante, un lutto.", img: "/images/attraversare-una-perdita.webp" },
];

const percheScegliermi = [
  { title: "Ho attraversato il mio cammino interiore", desc: "Prima di accompagnare gli altri, ho attraversato il mio percorso personale, chiamato \"opera al nero\": anni di lavoro interiore e confronto con le mie ombre.", icon: "/images/Compass_1Compass.png" },
  { title: "Un lavoro profondo sui sogni", desc: "Integro l'interpretazione dei sogni secondo l'approccio di Gabriella Tupini, uno strumento prezioso per accedere ai contenuti inconsci.", icon: "/images/Crescent-Moon_1Crescent-Moon.png" },
  { title: "Nessuna lente ideologica", desc: "Non porto credenze religiose o filosofiche nel percorso. Lo spazio che costruisco è neutro, aperto, libero.", icon: "/images/Scales_1Scales.png" },
  { title: "Un percorso costruito insieme", desc: "Ogni cammino nasce dall'ascolto autentico e si costruisce passo dopo passo, rispettando la tua storia, le tue relazioni e il tuo tempo.", icon: "/images/Heart_1Heart.png" },
  { title: "Oltre gli schemi mentali", desc: "Ho lavorato per sciogliere condizionamenti e automatismi della mente. Questo mi consente di ascoltare davvero.", icon: "/images/Ocean-Wave_1Ocean-Wave.png" },
];

const strumenti = [
  { num: "1", title: "Interpretazione dei sogni", desc: "I sogni parlano attraverso immagini e simboli. Aiutano a comprendere emozioni profonde, parti nascoste di noi e schemi che si ripetono.", icon: "/images/Crescent-Moon_1Crescent-Moon.png" },
  { num: "2", title: "Genogramma", desc: "Una mappa della storia familiare che aiuta a riconoscere dinamiche e schemi relazionali che influenzano il presente.", icon: "/images/Puzzle_1Puzzle.png" },
  { num: "3", title: "Costellazioni familiari", desc: "Permettono di osservare le dinamiche relazionali e familiari che influenzano il presente, per ritrovare il proprio posto con più chiarezza.", icon: "/images/Oak-Tree_1Oak-Tree.png" },
  { num: "4", title: "Scrittura espressiva e di consapevolezza", desc: "La scrittura può diventare uno spazio di ascolto interiore, per dare forma a emozioni, immagini e vissuti.", icon: "/images/Autograph_1Autograph.png" },
];

---

<Layout title="Christian Dilorenzo - Counselor">

  <!-- ═══════════ HERO ═══════════ -->
  <section class="pt-24 md:pt-32 pb-16">
    <div class="wrapper px-4 md:px-8 lg:px-12">
      <div class="mx-auto" data-animate="fade-in-up">
        <div class="flex flex-col lg:flex-row gap-7">
          <!-- Hero card -->
          <div class="group/hero bg-[#f4f2ee] rounded-[20px] relative overflow-hidden w-full px-8 py-12 md:px-16 md:py-16 flex flex-col gap-15">
            <div class="flex flex-col gap-7 max-w-[610px] relative z-[4]">
              <div class="flex flex-col gap-4">
                <h1>Uno spazio per <br><span class="italic font-medium">fermarti e fare chiarezza</span></h1>
                <p class="regular-text opacity-80 !mb-0">
                  Se stai vivendo un periodo di difficoltà, cambiamento o smarrimento, possiamo lavorarci insieme. Gli incontri sono <strong>un tempo dedicato a te</strong>, per comprendere meglio ciò che accade dentro e trasformarlo in <strong>consapevolezza, benessere ed equilibrio</strong>.
                </p>
              </div>
              <div class="flex flex-wrap items-center gap-4">
                <RainbowButton href={calendarUrl} client:load>
                  Prenota un colloquio gratuito
                  <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </RainbowButton>
                <a href="#chi-sono" class="btn-secondary group">
                  <span class="inline-flex items-center gap-2">
                    Chi sono
                    <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-y-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                  </span>
                </a>
              </div>
            </div>

            <!-- Rating card -->
            <a href="https://it.trustpilot.com/review/cridilorenzo.com" target="_blank" class="hero-review-card relative z-[4] group transition-all duration-300 hover:shadow-lg hover:-translate-y-1">
              <div class="flex flex-col gap-3">
                <div class="flex items-center gap-3">
                  <img loading="lazy" src="/images/kindpng_7219870.png" alt="Trustpilot" class="h-auto w-[140px] object-contain" />
                  <img src="/images/freccia-destra.svg" loading="lazy" alt="" class="w-4 h-4 opacity-50 transition-transform duration-300 group-hover:translate-x-1" />
                </div>
                <p class="text-[#15141a] text-lg font-medium leading-[156%] m-0">4.9/5 Soddisfazione clienti</p>
              </div>
              <p class="text-[#373737cc] text-base m-0 transition-colors duration-300 group-hover:text-[#15141a]">Scopri cosa raccontano le persone che hanno intrapreso questo percorso.</p>
            </a>

            <!-- Hero image (come nel Webflow: absolute, appiccicata a destra, esce dal box) -->
            <img loading="lazy" src="/images/christian-hero-section.webp" alt="Christian DiLorenzo" class="hidden lg:block absolute top-0 bottom-0 right-0 z-[1] h-full w-auto object-contain transition-transform duration-700 ease-out group-hover/hero:scale-[1.03]" />
            <!-- Sfumatura solo in basso -->
            <div class="hidden lg:block absolute bottom-0 right-0 z-[2] w-[50%] h-[30%] bg-gradient-to-t from-[#f4f2ee] to-transparent pointer-events-none"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ CHI SONO ═══════════ -->
  <section id="chi-sono" class="py-16 md:py-24">
    <div class="wrapper px-4 md:px-8 lg:px-12">
      <!-- Row 1: image left, text right -->
      <div class="grid grid-cols-1 md:grid-cols-[1.1fr_1fr] gap-8 items-center mb-12" data-animate="fade-in-up">
        <div class="relative">
          <div class="aspect-[3/2] overflow-hidden rounded-[20px]">
            <img src="/images/studio-da-councelor.webp" alt="Studio" loading="lazy" class="w-full h-full object-cover" />
          </div>
        </div>
        <div class="flex flex-col gap-2.5 max-w-[469px]">
          <div class="flex flex-wrap gap-2">
            <span class="tag-pill">Chi sono</span>
            <span class="tag-pill">counselor professionista</span>
          </div>
          <h3 class="text-[32px] font-medium text-[#15141a] tracking-tight mb-3">Ciao, sono Christian</h3>
          <p class="regular-text !text-base">
            Sono una persona che ha imparato, nel tempo, a <strong>fermarsi e ad ascoltarsi davvero</strong>. E oggi faccio questo anche con gli altri.<br><br>
            Sono counselor e accompagno le persone in uno <strong>spazio di ascolto</strong> e di <strong>esplorazione interiore</strong>, principalmente online.<br>
            Un luogo semplice, umano, dove poter portare ciò che si sente — <strong>confusione, stanchezza, emozioni che pesano, momenti di blocco</strong> — senza dover dimostrare nulla.<br><br>
            Il mio modo di lavorare nasce dal mio <strong>percorso personale</strong>.<br>
            So cosa significa sentirsi lontani da sé, non capirsi, vivere <strong>schemi che sembrano ripetersi</strong>.
          </p>
        </div>
      </div>

      <!-- Row 2: text left, image right -->
      <div class="grid grid-cols-1 md:grid-cols-[1fr_1.1fr] gap-8 items-center" data-animate="fade-in-up">
        <div class="flex flex-col gap-2.5 max-w-[469px] order-2 md:order-1">
          <p class="regular-text !text-base">
            So quanto può fare la differenza incontrare qualcuno che ti aiuta a guardarti dentro con <strong>rispetto e senza giudizio</strong>.<br><br>
            Uno degli strumenti che utilizzo è l'<strong>interpretazione dei sogni</strong>, perché i sogni parlano di noi in modo sincero e profondo.<br>
            A volte mostrano parti che durante il giorno non riusciamo a vedere, ma che hanno molto da dire sulla nostra vita, sulle nostre ferite e anche sulle nostre risorse.<br><br>
            Negli incontri non si tratta di "aggiustare" qualcosa, ma di <strong>incontrarsi</strong>, fare chiarezza, dare un nome a ciò che si muove dentro e <strong>ritrovare un po' più di spazio, respiro e libertà</strong> nel proprio modo di vivere.
          </p>
          <a href={calendarUrl} target="_blank" class="btn-primary self-start">Prenota un colloquio gratuito</a>
        </div>
        <div class="relative order-1 md:order-2">
          <div class="aspect-[3/2] overflow-hidden rounded-[20px]">
            <img src="/images/chi-sono_.webp" alt="Christian" loading="lazy" class="w-full h-full object-cover" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ SERVIZI (slider cards) ═══════════ -->
  <section id="servizi" class="bg-[#f4f2ee] py-16 md:py-20 overflow-hidden">
    <div class="wrapper px-4 md:px-8 lg:px-12">
      <div class="max-w-2xl mb-10" data-animate="fade-in-up">
        <p class="sub-title mb-3">[ SERVIZI ]</p>
        <h2>In cosa posso <span class="italic">accompagnarti</span></h2>
        <p class="regular-text mt-5">
          Ti accompagno quando senti che dentro qualcosa chiede attenzione, ma non sai bene da dove iniziare. Posso esserti accanto per:
        </p>
      </div>

      <!-- Horizontal scroll cards -->
      <div class="flex gap-6 overflow-x-auto pb-4 snap-x snap-mandatory scrollbar-hide" data-animate="fade-in-up">
        {servizi.map((s) => (
          <div class="flex-shrink-0 w-[280px] snap-start flex flex-col">
            <div class="rounded-[20px] overflow-hidden max-h-[250px] mb-5">
              <img src={s.img} alt={s.title} loading="eager" class="w-full h-full object-cover" />
            </div>
            <div class="flex flex-col gap-2.5">
              <h3 class="text-xl font-medium">{s.title}</h3>
              <p class="text-base text-[#3e3e3e] m-0">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Conclusione -->
      <div class="flex flex-col items-center mt-10 max-w-[650px] mx-auto text-center gap-4" data-animate="fade-in-up">
        <p class="regular-text text-center !mb-2">Ogni percorso è uno spazio di ascolto e di comprensione, dove ciò che senti ha valore e può trovare un significato.</p>
        <a href={calendarUrl} target="_blank" class="btn-primary">Prenota un colloquio gratuito</a>
      </div>
    </div>
  </section>

  <!-- ═══════════ COME FUNZIONA ═══════════ -->
  <section id="come-funziona" class="py-16 md:py-24">
    <div class="wrapper px-4 md:px-8 lg:px-12">

      <!-- Header + Image -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center mb-16" data-animate="fade-in-up">
        <div>
          <p class="sub-title mb-3">[ COME FUNZIONA ]</p>
          <h2>Un percorso <span class="italic">chiaro e trasparente</span></h2>
          <p class="regular-text mt-5">Dal primo contatto gratuito all'accompagnamento nel tempo, ogni passo è pensato per offrirti ascolto autentico e un sostegno costante.</p>
        </div>
        <div class="rounded-[20px] overflow-hidden aspect-[4/3]">
          <img src="/images/councelor.webp" alt="Counselor" loading="lazy" class="w-full h-full object-cover" />
        </div>
      </div>

      <!-- Il percorso — 3 righe impilate, tutte si espandono all'hover -->
      <div class="rounded-[20px] overflow-hidden bg-[#f4f2ee]" data-animate="fade-in-up">
        <div class="p-8 md:p-10">
          <h2 class="mb-2">Il <span class="italic">percorso</span></h2>
          <p class="text-lg mb-8">Nessun pacchetto obbligatorio. Paghi solo gli incontri che fai, senza vincoli.</p>

          <div class="flex flex-col gap-0 rounded-[15px] overflow-hidden">
            <!-- Passo 1 -->
            <div class="group bg-[#ebe7e0] p-6 md:p-8 cursor-default">
              <div class="flex flex-col md:flex-row md:items-center justify-between gap-2">
                <div class="flex flex-col md:flex-row md:items-center gap-2 md:gap-4">
                  <span class="text-sm font-bold text-[#2a9d8f] uppercase tracking-wider">Passo 1</span>
                  <h3 class="text-xl font-medium m-0">Prenota il colloquio conoscitivo gratuito</h3>
                </div>
                <span class="text-2xl font-bold flex-shrink-0 text-[#2a9d8f]">Gratuito</span>
              </div>
              <div class="grid grid-rows-[0fr] group-hover:grid-rows-[1fr] transition-[grid-template-rows] duration-400 ease-in-out">
                <div class="overflow-hidden">
                  <p class="text-base mt-5 m-0 leading-[170%]">Prenota un <strong>incontro gratuito di 45 minuti</strong> per conoscerci, comprendere la tua situazione e ascoltare le tue esigenze.</p>
                </div>
              </div>
            </div>

            <div class="h-px bg-[#d8d0c1]"></div>

            <!-- Passo 2 -->
            <div class="group bg-[#ebe7e0] p-6 md:p-8 cursor-default">
              <div class="flex flex-col md:flex-row md:items-center justify-between gap-2">
                <div class="flex flex-col md:flex-row md:items-center gap-2 md:gap-4">
                  <span class="text-sm font-bold text-[#2a9d8f] uppercase tracking-wider">Passo 2</span>
                  <h3 class="text-xl font-medium m-0">Ricevi una proposta per il tuo percorso</h3>
                </div>
                <span class="text-2xl font-bold flex-shrink-0 text-[#2a9d8f]">Gratuita</span>
              </div>
              <div class="grid grid-rows-[0fr] group-hover:grid-rows-[1fr] transition-[grid-template-rows] duration-400 ease-in-out">
                <div class="overflow-hidden">
                  <p class="text-base mt-5 m-0 leading-[170%]">Ti sarà inviata una <strong>sintesi</strong> di ciò che è emerso nel <strong>nostro incontro</strong>, insieme a una proposta di percorso e ai primi strumenti che potremo utilizzare.</p>
                </div>
              </div>
            </div>

            <div class="h-px bg-[#d8d0c1]"></div>

            <!-- Continuiamo — pricing con gradiente verde -->
            <div class="group p-6 md:p-8 cursor-default text-white" style="background: linear-gradient(135deg, #1a7a6f 0%, #2a9d8f 40%, #3bbfad 100%);">
              <div class="flex flex-col md:flex-row md:items-center justify-between gap-2">
                <div class="flex flex-col md:flex-row md:items-center gap-2 md:gap-4">
                  <span class="text-sm font-bold text-white/70 uppercase tracking-wider">Continuiamo</span>
                  <h3 class="text-xl font-medium text-white m-0">Ogni incontro successivo</h3>
                </div>
                <div class="flex items-baseline gap-2 flex-shrink-0">
                  <span class="text-3xl font-bold text-white">70€</span>
                  <span class="text-base text-white/70">/ 45 min</span>
                </div>
              </div>
              <div class="grid grid-rows-[0fr] group-hover:grid-rows-[1fr] transition-[grid-template-rows] duration-400 ease-in-out">
                <div class="overflow-hidden">
                  <div class="pt-5 mt-5 border-t border-white/20">
                    <p class="text-base text-white/90 mb-4">Online, con cadenza da concordare insieme.</p>
                    <ul class="flex flex-col gap-3">
                      <li class="flex items-start gap-3 text-base text-white/90">
                        <svg class="w-5 h-5 text-white flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        Ascolto, dialogo e strumenti dedicati
                      </li>
                      <li class="flex items-start gap-3 text-base text-white/90">
                        <svg class="w-5 h-5 text-white flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        Interpretazione dei sogni inclusa
                      </li>
                      <li class="flex items-start gap-3 text-base text-white/90">
                        <svg class="w-5 h-5 text-white flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        Nessun vincolo di durata minima
                      </li>
                      <li class="flex items-start gap-3 text-base text-white/90">
                        <svg class="w-5 h-5 text-white flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        Puoi interrompere in qualsiasi momento
                      </li>
                      <li class="flex items-start gap-3 text-base text-white/90">
                        <svg class="w-5 h-5 text-white flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        Riservatezza totale garantita
                      </li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="flex justify-center mt-10">
        <a href={calendarUrl} target="_blank" class="btn-primary">Prenota un colloquio gratuito</a>
      </div>

    </div>
  </section>

  <!-- ═══════════ PERCHÉ SCEGLIERE ME ═══════════ -->
  <section class="py-16 md:py-24">
    <div class="wrapper px-4 md:px-8 lg:px-12">
      <div class="text-center max-w-3xl mx-auto mb-12" data-animate="fade-in-up">
        <p class="sub-title mb-3">[ CHI SCEGLIERE ]</p>
        <h2 class="text-center">Perché scegliere me</h2>
        <p class="regular-text mt-5 text-center">Scegliere qualcuno con cui intraprendere un percorso interiore è una decisione delicata. Al di là dei titoli, ci sono qualità umane e professionali fondamentali.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6" data-animate="fade-in-up">
        {percheScegliermi.slice(0, 3).map((item) => (
          <div class="bg-[#ebe7e0] rounded-[20px] p-5 flex flex-col items-center text-center">
            <div class="icon-rounded">
              <img src={item.icon} alt="" class="w-7 h-7" loading="lazy" />
            </div>
            <h3 class="text-xl font-medium text-[#3e3e3e] mb-5">{item.title}</h3>
            <p class="text-base text-[#3e3e3e] m-0">{item.desc}</p>
          </div>
        ))}
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-animate="fade-in-up">
        {percheScegliermi.slice(3).map((item) => (
          <div class="bg-[#ebe7e0] rounded-[20px] p-5 flex flex-col items-center text-center">
            <div class="icon-rounded">
              <img src={item.icon} alt="" class="w-7 h-7" loading="lazy" />
            </div>
            <h3 class="text-xl font-medium text-[#3e3e3e] mb-5">{item.title}</h3>
            <p class="text-base text-[#3e3e3e] m-0">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════ DI COSA MI OCCUPO (tabs) ═══════════ -->
  <section class="py-16 md:py-24">
    <div class="wrapper px-4 md:px-8 lg:px-12">
      <div class="mb-10" data-animate="fade-in-up">
        <p class="sub-title mb-3">[ DI COSA MI OCCUPO ]</p>
        <h2>Ti accompagno in percorsi di <span class="italic">consapevolezza e crescita personale</span></h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-animate="fade-in-up">
        <div class="rounded-[20px] overflow-hidden relative">
          <img src="/images/Why-Chose-Img-01_1Why-Chose-Img-01.avif" style="min-height:300px" alt="Counseling" loading="lazy" class="w-full h-full object-cover" />
          <div class="absolute bottom-0 left-0 right-0 bg-[#15141a]/85 p-6 backdrop-blur-md">
            <h3 class="text-white text-xl font-medium mb-2">Percorso di Counseling</h3>
            <p class="text-white/80 text-sm m-0">Uno spazio di ascolto e accompagnamento per fare chiarezza, comprendere ciò che stai vivendo e ritrovare una direzione più autentica.</p>
          </div>
        </div>
        <div class="rounded-[20px] overflow-hidden relative">
          <img src="/images/interpretazione-sogni-psicoterapia-centro-psicologia-lecco-1.png" alt="Sogni" loading="lazy" class="w-full h-full object-cover" />
          <div class="absolute bottom-0 left-0 right-0 bg-[#15141a]/85 p-6 backdrop-blur-md">
            <h3 class="text-white text-xl font-medium mb-2">Interpretazione dei Sogni</h3>
            <p class="text-white/80 text-sm m-0">I sogni come linguaggio simbolico dell'inconscio: uno strumento prezioso per esplorare parti profonde di te.</p>
          </div>
        </div>
        <div class="rounded-[20px] overflow-hidden relative">
          <img src="/images/counseling-1500x430-1.png" alt="Relazioni" loading="lazy" class="w-full h-full object-cover min-h-[300px]" />
