  <script is:inline>
    (function () {
      function fill() {
        document.querySelectorAll("[data-marquee]").forEach(function (track) {
          var contents = track.querySelectorAll(".marquee-content");
          if (contents.length < 1) return;
          var first = contents[0];
          first.querySelectorAll("[data-mq-fill]").forEach(function (n) { n.remove(); });
          var base = Array.prototype.slice.call(first.children);
          var safety = 0;
          while (first.scrollWidth < track.offsetWidth && safety++ < 20) {
            base.forEach(function (ch) {
              var c = ch.cloneNode(true);
              c.setAttribute("data-mq-fill", "");
              first.appendChild(c);
            });
          }
          for (var i = 1; i < contents.length; i++) {
            contents[i].innerHTML = first.innerHTML;
          }
        });
      }
      var t;
      function schedule() { clearTimeout(t); t = setTimeout(fill, 80); }
      document.addEventListener("astro:page-load", schedule);
      window.addEventListener("resize", schedule);
      if (document.readyState !== "loading") schedule(); else document.addEventListener("DOMContentLoaded", schedule);
    })();
  </script>

