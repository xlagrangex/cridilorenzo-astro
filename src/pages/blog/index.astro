---
import Layout from "../../layouts/Layout.astro";
import { getAllPosts } from "../../lib/sanity";

const posts = await getAllPosts();
---

<Layout title="Blog — Christian DiLorenzo" description="Articoli su counseling, crescita personale, interpretazione dei sogni e consapevolezza.">
  <section class="pt-28 md:pt-36 pb-16">
    <div class="wrapper px-4 md:px-8 lg:px-12">
      <div class="max-w-3xl mb-12" data-animate="fade-in-up">
        <p class="sub-title mb-3">[ BLOG ]</p>
        <h1 class="!text-[3.25rem]">Articoli e <span class="italic">riflessioni</span></h1>
        <p class="regular-text mt-5">Pensieri sul counseling, la crescita personale, l'interpretazione dei sogni e il percorso verso una maggiore consapevolezza.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" data-animate="fade-in-up">
        {posts.map((post) => (
          <a href={`/blog/${post.slug.current}`} class="group block rounded-[20px] bg-[#f4f2ee] overflow-hidden transition-all duration-300 hover:shadow-lg hover:-translate-y-1">
            {post.image?.asset?.url && (
              <div class="aspect-[16/10] overflow-hidden">
                <img
                  src={post.image.asset.url}
                  alt={post.title}
                  loading="lazy"
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
              </div>
            )}
            <div class="p-6">
              {post.tags && (
                <div class="flex flex-wrap gap-2 mb-3">
                  {post.tags.map((tag: string) => (
                    <span class="tag-pill !text-xs">{tag}</span>
                  ))}
                </div>
              )}
              <h3 class="text-xl font-medium text-[#15141a] mb-2 group-hover:text-[#2a9d8f] transition-colors duration-300">{post.title}</h3>
              <p class="text-sm text-[#3e3e3e] mb-3 line-clamp-2">{post.description}</p>
              <time class="text-xs text-[#373737cc]">
                {new Date(post.date).toLocaleDateString("it-IT", { day: "numeric", month: "long", year: "numeric" })}
              </time>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  import { fadeInUp } from "../../lib/animations";
  document.addEventListener("astro:page-load", () => {
    fadeInUp('[data-animate="fade-in-up"]');
  });
</script>
