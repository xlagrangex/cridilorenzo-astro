---
const socialLinks = [
  { label: "Facebook", href: "https://www.facebook.com/cridilorenzo/", icon: "/images/Footer-Social-Icon.svg" },
  { label: "Instagram", href: "https://www.instagram.com/cridilorenzo", icon: "/images/instagram-stroke-rounded.svg" },
  { label: "YouTube", href: "https://www.youtube.com/@cridilorenzo", icon: "/images/youtube-stroke-rounded.svg" },
  { label: "TikTok", href: "https://www.tiktok.com/@cridilorenzo", icon: "/images/TikTok.svg" },
];

const pageLinks = [
  { label: "Chi sono", href: "/#chi-sono" },
  { label: "Servizi", href: "/#servizi" },
  { label: "Come funziona", href: "/#come-funziona" },
  { label: "Blog", href: "/blog" },
  { label: "Strumenti", href: "/#strumenti" },
  { label: "FAQ", href: "/#faq" },
  { label: "Contatti", href: "/#contact" },
];
---

<footer class="bg-[#15141a] relative">
  <!-- Bordo rainbow animato in cima -->
  <div class="absolute top-0 left-0 right-0 h-[3px] animate-footer-rainbow" style="background: linear-gradient(90deg, #2a9d8f, #0d4f46, #5cead8, #134e44, #3bbfad, #0a3d36, #2a9d8f); background-size: 200% 100%;"></div>
  <!-- Glow diffuso sopra il bordo (verso l'alto, fuori dal footer) -->
  <div class="absolute -top-[25px] left-0 right-0 h-[35px] animate-footer-rainbow opacity-50 pointer-events-none" style="background: linear-gradient(90deg, #2a9d8f, #0d4f46, #5cead8, #134e44, #3bbfad, #0a3d36, #2a9d8f); background-size: 200% 100%; filter: blur(18px);"></div>

  <div class="wrapper px-4 md:px-8 lg:px-12 pt-16 pb-6 relative z-10">

    <!-- Logo -->
    <div class="mb-10">
      <img src="/images/logo-dilorenzo.png" alt="Christian Di Lorenzo" class="h-10 md:h-12 w-auto brightness-0 invert" />
    </div>

    <!-- Top: Newsletter + Social -->
    <div class="flex flex-col md:flex-row gap-10 md:gap-16 mb-12">
      <!-- Left: Newsletter in box gradient -->
      <div class="flex-1 rounded-[20px] p-7 md:p-8 group/nl" style="background: linear-gradient(135deg, #1a7a6f 0%, #2a9d8f 40%, #3bbfad 100%);">
        <div class="flex items-start gap-5 mb-5">
          <!-- Icona regalo/PDF -->
          <div class="flex-shrink-0 w-14 h-14 rounded-[12px] bg-white/15 flex items-center justify-center transition-transform duration-500 group-hover/nl:rotate-[-8deg] group-hover/nl:scale-110">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 11.25v8.25a1.5 1.5 0 01-1.5 1.5H5.25a1.5 1.5 0 01-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 109.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1114.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-white text-[1.6rem] font-medium mb-1">Ricevi la guida gratuita</h3>
            <p class="text-white/80 text-sm leading-[160%] m-0">
              Iscriviti alla newsletter e ricevi subito la <strong class="text-white">mini-guida all'interpretazione dei sogni</strong> — scopri come ascoltare il linguaggio della tua anima.
            </p>
          </div>
        </div>
        <form id="newsletter-form" class="flex flex-col gap-3">
          <input type="hidden" name="tipo" value="Newsletter" />
          <input
            type="email"
            name="email"
            placeholder="Indirizzo email"
            required
            class="bg-white/20 border border-white/20 rounded-[10px] px-5 py-3 text-white placeholder:text-white/60 text-base focus:border-white/50 outline-none"
          />
          <label class="flex items-center gap-3 text-white/70 text-sm cursor-pointer">
            <input type="checkbox" required class="w-4 h-4 accent-white rounded flex-shrink-0" />
            <span>Acconsento al trattamento dei dati e all'iscrizione alla newsletter. <a href="https://www.iubenda.com/privacy-policy/19514849" target="_blank" class="underline text-white/90 hover:text-white">Privacy Policy</a></span>
          </label>
          <button type="submit" class="bg-white text-[#15141a] rounded-[10px] px-5 py-3 text-sm font-semibold hover:bg-white/90 transition-colors">
            Ricevi la guida
          </button>
        </form>
        <script is:inline>
          document.addEventListener("DOMContentLoaded", function() {
            var form = document.getElementById("newsletter-form");
            if (!form) return;
            form.addEventListener("submit", function(e) {
              e.preventDefault();
              e.stopPropagation();
              var btn = form.querySelector("button");
              var originalText = btn.textContent;
              btn.textContent = "Invio...";
              btn.disabled = true;
              var fd = new FormData(form);
              fd.set("name", "—");
              fetch("/api/contact", { method: "POST", body: fd })
                .then(function(res) {
                  if (res.ok) {
                    form.reset();
                    if (window.showToast) window.showToast("Iscrizione confermata! Controlla la tua email.", "success");
                  } else {
                    if (window.showToast) window.showToast("Ops, qualcosa non ha funzionato.", "error");
                  }
                })
                .catch(function() {
                  if (window.showToast) window.showToast("Errore di connessione.", "error");
                })
                .finally(function() {
                  btn.textContent = originalText;
                  btn.disabled = false;
                });
            });
          });
        </script>
      </div>

      <!-- Right: Social links -->
      <div class="flex-1 md:max-w-xs">
        <h3 class="text-white text-xl font-medium mb-6">Seguimi <span class="font-[family-name:var(--font-serif)] italic text-2xl">su ...</span></h3>
        <div class="flex flex-col gap-4">
          {socialLinks.map((s) => (
            <a href={s.href} target="_blank" rel="noopener noreferrer" class="group flex items-center justify-between py-2 border-b border-white/10">
              <span class="text-white text-base font-medium transition-opacity group-hover:opacity-60">{s.label}</span>
              <img src={s.icon} alt={s.label} class="w-5 h-5 brightness-0 invert opacity-80 group-hover:opacity-100 transition-opacity" loading="lazy" />
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Bottom cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
      <!-- Pagine -->
      <div class="border border-white/10 rounded-[15px] p-5">
        <h4 class="text-white font-medium mb-3"><span class="font-[family-name:var(--font-serif)] italic text-xl">Pagine</span></h4>
        <div class="grid grid-cols-2 gap-2">
          {pageLinks.map((link) => (
            <a href={link.href} class="group relative overflow-clip h-[24px]">
              <span class="block text-white/70 text-sm transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:-translate-y-full">{link.label}</span>
              <span class="absolute inset-0 block text-white text-sm translate-y-full transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:translate-y-0">{link.label}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Contatti -->
      <div class="border border-white/10 rounded-[15px] p-5">
        <h4 class="text-white font-medium mb-4"><span class="font-[family-name:var(--font-serif)] italic text-xl">Contatti</span></h4>
        <div class="flex flex-col gap-3">
          <a href="mailto:info@cridilorenzo.com" class="flex items-center gap-2.5 text-white/70 text-sm hover:text-white transition-colors">
            <svg class="w-4 h-4 opacity-50 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            info@cridilorenzo.com
          </a>
          <a href="tel:+393473301278" class="flex items-center gap-2.5 text-white/70 text-sm hover:text-white transition-colors">
            <svg class="w-4 h-4 opacity-50 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
            +39 347 330 1278
          </a>
          <a href="https://api.whatsapp.com/send/?phone=393473301278" target="_blank" class="flex items-center gap-2.5 text-white/70 text-sm hover:text-white transition-colors">
            <svg class="w-4 h-4 opacity-50 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <div class="h-px bg-white/5 my-1"></div>
          <span class="flex items-center gap-2.5 text-white/40 text-xs">
            <svg class="w-3.5 h-3.5 opacity-50 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Rispondo entro 24 ore
          </span>
        </div>
      </div>

      <!-- Dove sono -->
      <div class="border border-white/10 rounded-[15px] p-5">
        <h4 class="text-white font-medium mb-4"><span class="font-[family-name:var(--font-serif)] italic text-xl">Dove sono</span></h4>
        <div class="flex flex-col gap-3">
          <span class="flex items-center gap-2.5 text-white/70 text-sm">
            <svg class="w-4 h-4 opacity-50 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
            Milano (MI)
          </span>
          <span class="flex items-center gap-2.5 text-white/70 text-sm">
            <svg class="w-4 h-4 opacity-50 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25"/></svg>
            Ricevo esclusivamente online
          </span>
          <div class="h-px bg-white/5 my-1"></div>
          <span class="flex items-center gap-2.5 text-white/40 text-xs">
            <svg class="w-3.5 h-3.5 opacity-50 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
            P.IVA 14452680961
          </span>
          <span class="flex items-center gap-2.5 text-white/40 text-xs">
            <svg class="w-3.5 h-3.5 opacity-50 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/></svg>
            Counselor professionista
          </span>
        </div>
      </div>
    </div>

    <!-- Disclaimer espandibile -->
    <details class="mb-6 group">
      <summary class="flex items-center gap-2 cursor-pointer text-white/30 text-xs font-medium hover:text-white/50 transition-colors select-none">
        <svg class="w-3.5 h-3.5 transition-transform duration-200 group-open:rotate-90" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        Disclaimer — Nota importante sul counseling
      </summary>
      <div class="mt-3 text-white/30 text-[0.7rem] leading-[180%] max-w-4xl space-y-2">
        <p class="m-0">Christian Di Lorenzo è un counselor professionista, non uno psicologo né uno psicoterapeuta. Il counseling non è un'attività sanitaria e non prevede diagnosi, trattamento o cura di patologie psicologiche o psichiatriche.</p>
        <p class="m-0">Il counseling non sostituisce in alcun modo la psicoterapia o il supporto psicologico. In caso di disagio significativo si consiglia di rivolgersi a un professionista sanitario qualificato.</p>
        <p class="m-0">Christian Di Lorenzo opera nel rispetto del codice etico professionale e della riservatezza. I contenuti presenti su questo sito hanno finalità informativa.</p>
      </div>
    </details>

    <!-- Copyright + iubenda -->
    <div class="border-t border-white/10 pt-5 flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
      <span class="text-white/40 text-xs">&copy; {new Date().getFullYear()} Christian Di Lorenzo — Counselor Professionista. Tutti i diritti riservati.</span>
      <div class="flex items-center gap-4">
        <a href="https://www.iubenda.com/privacy-policy/19514849" class="iubenda-white iubenda-noiframe iubenda-embed text-white/40 text-xs hover:text-white/70 transition-colors" title="Privacy Policy">Privacy Policy</a>
        <a href="https://www.iubenda.com/privacy-policy/19514849/cookie-policy" class="iubenda-white iubenda-noiframe iubenda-embed text-white/40 text-xs hover:text-white/70 transition-colors" title="Cookie Policy">Cookie Policy</a>
      </div>
    </div>
    <script is:inline>
      (function (w,d) {var loader = function () {var s = d.createElement("script"), tag = d.getElementsByTagName("script")[0]; s.src="https://cdn.iubenda.com/iubenda.js"; tag.parentNode.insertBefore(s,tag);}; if(w.addEventListener){w.addEventListener("load", loader, false);}else if(w.attachEvent){w.attachEvent("onload", loader);}else{w.onload = loader;}})(window, document);
    </script>

  </div>

  <!-- Credits BizStudio -->
  <div class="border-t border-white/10 py-5">
    <a href="https://bizstudio.it" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-3 group/biz">
      <img src="/images/bizstudio-logo.png" alt="BizStudio" class="h-5 w-auto opacity-80 group-hover/biz:opacity-100 transition-opacity" />
      <span class="text-white/50 text-xs group-hover/biz:text-white/90 transition-colors">Sito realizzato da BizStudio</span>
    </a>
  </div>
</footer>
