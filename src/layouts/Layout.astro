---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import SmoothScroll from "../components/react/SmoothScroll.tsx";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Counselor professionista: percorsi di ascolto e crescita personale per ritrovare equilibrio, chiarezza e benessere emotivo."
} = Astro.props;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <SmoothScroll client:load />

    <div id="site-content">
      <Navbar />
      <slot />
      <Footer />
    </div>

    <!-- WhatsApp floating button -->
    <a
      href="https://api.whatsapp.com/send/?phone=393473301278&text=Ciao%2C+vorrei+maggiori+informazioni&type=phone_number&app_absent=0"
      target="_blank"
      rel="noopener noreferrer"
      class="fixed bottom-6 right-6 z-50 transition-transform duration-300 hover:scale-110"
    >
      <img src="/images/image-297_1image-297.png" loading="lazy" alt="WhatsApp" class="w-14 h-14" />
    </a>

    <!-- Toast container -->
    <div id="toast-container" class="fixed top-6 right-6 z-[999] flex flex-col gap-3 pointer-events-none"></div>
  </body>
</html>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Toast notification globale
  (window as any).showToast = function(message: string, type: "success" | "error" = "success") {
    const container = document.getElementById("toast-container");
    if (!container) return;

    const icon = type === "success"
      ? '<svg width="20" height="20" fill="none" stroke="#2a9d8f" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>'
      : '<svg width="20" height="20" fill="none" stroke="#e53e3e" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>';

    const toast = document.createElement("div");
    toast.className = `toast toast-${type}`;
    toast.innerHTML = `${icon}<span>${message}</span>`;
    container.appendChild(toast);

    setTimeout(() => {
      toast.classList.add("toast-exit");
      setTimeout(() => toast.remove(), 300);
    }, 4000);
  };

  function showToast(message: string, type: "success" | "error" = "success") {
    (window as any).showToast(message, type);
  }

  document.addEventListener("astro:before-swap", () => {
    ScrollTrigger.getAll().forEach(t => t.kill());
    gsap.killTweensOf("*");
  });

  document.addEventListener("astro:page-load", () => {
    // Delay refresh per dare tempo alle pagine di re-inizializzare le animazioni
    requestAnimationFrame(() => {
      ScrollTrigger.refresh();
    });

    // Liquid blob fill — traccia posizione mouse sui bottoni
    document.querySelectorAll<HTMLElement>(".btn-primary, .btn-secondary, .btn-submit").forEach((btn) => {
      btn.addEventListener("mouseenter", (e) => {
        const rect = btn.getBoundingClientRect();
        const x = ((e as MouseEvent).clientX - rect.left) / rect.width * 100;
        const y = ((e as MouseEvent).clientY - rect.top) / rect.height * 100;
        btn.style.setProperty("--blob-x", x + "%");
        btn.style.setProperty("--blob-y", y + "%");
      });
    });
  });
</script>
